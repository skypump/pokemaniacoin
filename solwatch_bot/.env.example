# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# Your pump.fun deploy wallet (the one you used to create the coin)
# Export from Phantom: Settings > Security & Privacy > Export Private Key
DEPLOY_WALLET_PRIVATE_KEY=your_base58_private_key_here
DEPLOY_WALLET_PUBLIC_KEY=your_public_key_here

# Paste the mint address from the pump.fun URL after you deploy the coin:
# e.g. pump.fun/coin/ABC123... -> CASHIER_MINT_ADDRESS=ABC123...
SOLWATCH_MINT_ADDRESS=set_after_coin_deploy

# Helius free tier: https://dev.helius.xyz/dashboard/app
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# Bot mechanic constants — change only if you alter the rules
MAGIC_PHRASE=hire me
AIRDROP_INTERVAL_SECONDS=600
MIN_PAYOUT_USD=0.5
SOL_PRICE_CACHE_SECONDS=60
SCORE_EXPONENT=1.3
PRIZE_FRACTION=0.8

# Set to "devnet" for testing, "mainnet-beta" for live
SOLANA_NETWORK=mainnet-beta
